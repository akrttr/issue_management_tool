# Flask backend configuration for GKT1 Satellite Tracker

# Server
PORT=5001

# TLE Data Source
# Use Celestrak or Space-Track (requires account)
TLE_SOURCE_URL=https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=tle

# Satellite Identification
# Replace with actual GKT1 NORAD ID when available
# Current default is ISS (25544) for testing
NORAD_ID=25544

# Ground Station Coordinates
# Ankara, Turkey
GS_LATITUDE=39.9334
GS_LONGITUDE=32.8597
GS_ALTITUDE=0.9

# Pass Prediction
# Minimum elevation angle in degrees
MIN_ELEVATION=10